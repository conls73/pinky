# Server-side secrets — used ONLY inside app/*+api.ts route handlers.
# Copy to .env and fill in. Never commit .env.

# Claude API key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=

# SearchApi.io key for live Google Jobs (https://www.searchapi.io/)
# If empty, the search still works but returns sample leads instead of live ones.
SEARCHAPI_KEY=

# OpenAI key (https://platform.openai.com/) — ranking ("why it fits") + cover letters.
OPENAI_API_KEY=